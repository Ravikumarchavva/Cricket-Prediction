		{
			"name": "[concat(parameters('factoryName'), '/dataflow1')]",
			"type": "Microsoft.DataFactory/factories/dataflows",
			"apiVersion": "2018-06-01",
			"properties": {
				"type": "MappingDataFlow",
				"typeProperties": {
					"sources": [
						{
							"dataset": {
								"referenceName": "deliveries",
								"type": "DatasetReference"
							},
							"name": "deliveries"
						},
						{
							"dataset": {
								"referenceName": "matches",
								"type": "DatasetReference"
							},
							"name": "matches"
						}
					],
					"sinks": [
						{
							"dataset": {
								"referenceName": "mergingdm",
								"type": "DatasetReference"
							},
							"name": "output",
							"rejectedDataLinkedService": {
								"referenceName": "AzureBlobStorage1",
								"type": "LinkedServiceReference"
							}
						}
					],
					"transformations": [
						{
							"name": "merge"
						},
						{
							"name": "combined"
						}
					],
					"scriptLines": [
						"source(output(",
						"          match_id as string,",
						"          season as string,",
						"          start_date as string,",
						"          venue as string,",
						"          innings as string,",
						"          ball as string,",
						"          batting_team as string,",
						"          bowling_team as string,",
						"          striker as string,",
						"          non_striker as string,",
						"          bowler as string,",
						"          runs_off_bat as string,",
						"          extras as string,",
						"          wides as string,",
						"          noballs as string,",
						"          byes as string,",
						"          legbyes as string,",
						"          penalty as string,",
						"          wicket_type as string,",
						"          player_dismissed as string,",
						"          other_wicket_type as string,",
						"          other_player_dismissed as string",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: true,",
						"     ignoreNoFilesFound: false) ~> deliveries",
						"source(output(",
						"          team1 as string,",
						"          team2 as string,",
						"          gender as string,",
						"          season as string,",
						"          date as string,",
						"          venue as string,",
						"          city as string,",
						"          toss_winner as string,",
						"          toss_decision as string,",
						"          winner as string,",
						"          match_id as string",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: true,",
						"     ignoreNoFilesFound: false) ~> matches",
						"deliveries, matches join(deliveries@match_id == matches@match_id,",
						"     joinType:'inner',",
						"     matchType:'exact',",
						"     ignoreSpaces: false,",
						"     broadcast: 'auto')~> merge",
						"merge select(mapColumn(",
						"          match_id = deliveries@match_id,",
						"          innings,",
						"          ball,",
						"          batting_team,",
						"          bowling_team,",
						"          striker,",
						"          non_striker,",
						"          bowler,",
						"          runs_off_bat,",
						"          extras,",
						"          wides,",
						"          noballs,",
						"          byes,",
						"          legbyes,",
						"          penalty,",
						"          wicket_type,",
						"          player_dismissed,",
						"          other_wicket_type,",
						"          other_player_dismissed,",
						"          team1,",
						"          team2,",
						"          gender,",
						"          season = matches@season,",
						"          date,",
						"          venue = matches@venue,",
						"          city,",
						"          toss_winner,",
						"          toss_decision,",
						"          winner",
						"     ),",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true) ~> combined",
						"combined sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     partitionFileNames:['output.csv'],",
						"     truncate: true,",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true,",
						"     partitionBy('hash', 1)) ~> output"
					]
				}
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/datasets/deliveries')]",
				"[concat(variables('factoryId'), '/datasets/matches')]",
				"[concat(variables('factoryId'), '/datasets/mergingdm')]",
				"[concat(variables('factoryId'), '/linkedServices/AzureBlobStorage1')]"
			]
